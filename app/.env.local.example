# ============================================================
# あいおい塾 環境変数テンプレート
# このファイルをコピーして「.env.local」という名前で保存し、
# 実際の値を入力してください。
# .env.local は .gitignore により GitHub には絶対アップされません。
# ============================================================

# Supabase 接続情報（SupabaseダッシュボードのAPI Keysから取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx...

# Supabase サービスロールキー（管理者操作専用・絶対に外部公開しない）
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx...
